{
   "action": {
      "default_icon": {
         "128": "images/icon-128.png",
         "16": "images/icon-16.png",
         "48": "images/icon-48.png"
      },
      "default_popup": "popup/popup.html"
   },
   "background": {
      "service_worker": "service-worker.js",
      "type": "module"
   },
   "content_scripts": [ {
      "js": [ "content-scripts/common.js", "content-scripts/chatgpt.js" ],
      "matches": [ "https://chat.openai.com/*", "https://chatgpt.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/common.js", "content-scripts/claude.js" ],
      "matches": [ "https://claude.ai/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/common.js", "content-scripts/gemini.js" ],
      "matches": [ "https://gemini.google.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/common.js", "content-scripts/aistudio.js" ],
      "matches": [ "https://aistudio.google.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/common.js", "content-scripts/xiaomi-aistudio.js" ],
      "matches": [ "https://aistudio.xiaomimimo.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/common.js", "content-scripts/deepseek.js" ],
      "matches": [ "https://chat.deepseek.com/*" ],
      "run_at": "document_idle"
   } ],
   "description": "Queue and auto-send prompts to ChatGPT, Claude, Gemini, AI Studio, Xiaomi MiMo Studio, and DeepSeek",
   "host_permissions": [ "https://chat.openai.com/*", "https://chatgpt.com/*", "https://claude.ai/*", "https://gemini.google.com/*", "https://aistudio.google.com/*", "https://aistudio.xiaomimimo.com/*", "https://chat.deepseek.com/*" ],
   "icons": {
      "128": "images/icon-128.png",
      "16": "images/icon-16.png",
      "48": "images/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "LLM Prompt Queue",
   "permissions": [ "storage", "activeTab", "scripting", "tabs", "webNavigation" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0"
}
